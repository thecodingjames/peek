{
  "name": "peek",
  "version": "0.0.1",
  "description": "A minimal GUI HTTP client",
  "keywords": [
    "gui",
    "http client",
    "electronjs",
    "vuejs",
    "vuetify"
  ],
  "build": {
    "appId": "ca.codingjames.peek",
    "asar": true,
    "publish": null,
    "win": {
      "icon": "build/icon.png",
      "target": [
        "portable"
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage"
      ]
    }
  },
  "homepage": "https://github.com/thecodingjames/peek#readme",
  "bugs": {
    "url": "https://github.com/thecodingjames/peek/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thecodingjames/peek.git"
  },
  "license": "MIT",
  "author": "James Hoffman",
  "type": "commonjs",
  "main": "src/main.js",
  "scripts": {
    "dev": "npx electron .",
    "build": "electron-builder build"
  },
  "devDependencies": {
    "electron": "^41.4.0",
    "electron-builder": "^26.8.1"
  }
}
